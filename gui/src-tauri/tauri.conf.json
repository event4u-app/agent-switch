{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "agent-switch",
  "version": "1.0.0",
  "identifier": "com.event4u.agent-switch",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "agent-switch",
        "width": 380,
        "height": 560,
        "visible": false,
        "resizable": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": false
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "msi", "nsis"],
    "icon": ["icons/icon.png"]
  }
}

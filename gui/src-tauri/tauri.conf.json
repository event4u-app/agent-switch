{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "agent-switch",
  "version": "1.4.1",
  "identifier": "com.event4u.agent-switch",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "agent-switch",
        "width": 1040,
        "height": 620,
        "minWidth": 640,
        "minHeight": 480,
        "visible": false,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 12, "y": 24 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": "^https://github\\.com/event4u-app/(agent-switch|agent-config)"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

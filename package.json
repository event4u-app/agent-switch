{
  "name": "@event4u/agent-switch",
  "version": "1.6.0",
  "description": "Switch between multiple Claude Code accounts on macOS, Linux, and Windows via isolated CLAUDE_CONFIG_DIR profiles",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/event4u-app/agent-switch.git"
  },
  "type": "module",
  "bin": {
    "agent-switch": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "prepare": "npm run build",
    "prepack": "node scripts/prepack-check.mjs",
    "test": "tsc -p tsconfig.test.json && cd dist-test && node --test"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.20.1",
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "playwright": "^1.49.0"
  }
}
